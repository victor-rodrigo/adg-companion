{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ADG Companion",
  "version": "0.0.2",
  "identifier": "com.adg.companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ADG Companion",
        "width": 420,
        "height": 560,
        "resizable": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCNDdGQTREMjM1QTY2M0EKUldRNlpsb2pUZnBIS3owSWt6cDdJTUljRTA1ZFozbnphNnVzK044Snk1M1dQd0hRYWtMcGVXUXQK",
      "endpoints": [
        "https://github.com/victor-rodrigo/adg-companion/releases/latest/download/latest.json"
      ]
    }
  }
}
